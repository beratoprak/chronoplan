{
  "name": "toprak",
  "version": "0.9.0",
  "description": "Toprak — Profesyonel takvim, planlama ve araştırma uygulaması",
  "main": "main.js",
  "author": "Bera Toprak <bera@beratoprak.com>",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.beratoprak.toprak",
    "productName": "Toprak",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "identity": null,
      "target": [
        {
          "target": "dir",
          "arch": ["arm64"]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Toprak",
      "backgroundColor": "#F5F0E8"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.icns"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
